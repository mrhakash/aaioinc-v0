{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/geo-checker",
      "destination": "/tools/geo-checker",
      "permanent": true
    },
    {
      "source": "/humanizer",
      "destination": "/tools/humanizer",
      "permanent": true
    },
    {
      "source": "/niche-scorer",
      "destination": "/tools/niche-scorer",
      "permanent": true
    },
    {
      "source": "/tools/geo-score",
      "destination": "/tools/geo-checker",
      "permanent": true
    },
    {
      "source": "/tools/content-humanizer",
      "destination": "/tools/humanizer",
      "permanent": true
    },
    {
      "source": "/blog/geo",
      "destination": "/geo",
      "permanent": true
    },
    {
      "source": "/blog/geo/:path*",
      "destination": "/geo/:path*",
      "permanent": true
    },
    {
      "source": "/ai-tools",
      "destination": "/tools",
      "permanent": true
    },
    {
      "source": "/services/seo",
      "destination": "/services/ai-seo",
      "permanent": true
    },
    {
      "source": "/services/content",
      "destination": "/services/ai-content",
      "permanent": true
    },
    {
      "source": "/services/blogging",
      "destination": "/services/ai-blogging",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ]
}
